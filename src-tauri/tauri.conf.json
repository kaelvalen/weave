{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Weave",
  "version": "0.2.0",
  "identifier": "com.weave.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Weave",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": ["**"]
      },
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc://localhost http://localhost:* https://api.openai.com https://api.anthropic.com",
        "img-src": "'self' data: asset: http://tauri.localhost",
        "media-src": "'self' data: asset: http://tauri.localhost",
        "style-src": "'self' 'unsafe-inline'"
      },
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}